{"pdf_page": 384, "w": 1434, "h": 2330, "dpi": 300, "blocks": [{"order": 0, "label": "SectionHeader", "conf": 0.947, "html": "<p>PLATE No. 10.</p>", "bbox": [557.826, 274.94, 870.438, 321.54]}, {"order": 1, "label": "Text", "conf": 0.947, "html": "<p>MĀRTAND or SHRI KHANDERĀV.</p>", "bbox": [134.796, 386.78000000000003, 721.302, 438.04]}, {"order": 2, "label": "Text", "conf": 0.947, "html": "<p>A representation of the Sun, destroying the demon of darkness. For folklore see Champā Shashthi, page 19.</p>", "bbox": [217.968, 489.29999999999995, 1312.1100000000001, 598.8100000000001]}]}